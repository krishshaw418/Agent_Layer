generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  publicKey String   @unique
  nonce   String?   @unique
  createdAt DateTime @default(now())
}

model APIKey {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  keyHash   String   @unique
  KeyName   String
  KeyStartingCharacter String
  userPublicKey String
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)
}

model Job {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt       DateTime @default(now()) @map("created_at")
  status          String   @default("pending")

  // job details
  plan            Json

  // constraints
  maxTokenAmount         Float @map("max_token_amount")
  deadline        Int @map("deadline")
  priority        String @map("priority")
  quality         String @map("quality")

  // requirements
  minReputation   Float @map("min_reputation")

  createdBy       String   @map("created_by")

  @@index([status])
}

enum BidStatus {
  pending
  accepted
  rejected
}

model Bid {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  jobId         String   @map("job_id")
  nodePublicKey String   @map("node_public_key")
  placedAt      Int      @map("placed_at")
  token         Int
  timeRequired  Int      @map("time_requires")
  model         String
  reputation    Float
  status        BidStatus @default(pending)

  @@index([jobId])
  @@index([nodePublicKey])
  @@index([placedAt])
}